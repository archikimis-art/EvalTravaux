    "@prisma/client": "^5.17.0",
    "passport": "^0.7.0",
    "nodemailer": "^6.9.0",
    "stripe": "^14.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
