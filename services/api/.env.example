DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evaltravaux"
JWT_SECRET="change-me-in-production"
# CORS : URL(s) du frontend autorisées. Plusieurs domaines séparés par des virgules.
# En prod : https://evaltravaux.fr,https://evaltravaux.paris
CORS_ORIGIN="http://localhost:3000"
PORT=3001

# Optionnel : envoi d’emails réels (sinon log en console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=EvalTravaux <noreply@evaltravaux.fr>

# Stripe (paiement des packs de crédits). Les URLs success/cancel sont envoyées par le client.
# Sur Render : ajouter STRIPE_SECRET_KEY dans Environment.
# STRIPE_SECRET_KEY=sk_test_...
