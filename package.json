{
  "name": "evaltravaux-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "build:web": "npm run build -w web",
    "start:web": "npm run start -w web",
    "dev:api": "npm run start:dev -w api",
    "build:api": "npm run build -w api",
    "start:api": "npm run start -w api",
    "test": "npm run test -w api",
    "lint": "turbo lint",
    "dev": "turbo dev",
    "build": "turbo build"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
