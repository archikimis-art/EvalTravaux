##############################################
# EvalTravaux – configuration front (Next.js)
##############################################

### URL de l’API EvalTravaux
# En local (via npm run dev ou docker-compose) :
NEXT_PUBLIC_API_URL="http://localhost:3001"

# En production, à remplacer par l’URL publique de l’API NestJS,
# par exemple : https://evaltravaux-api.onrender.com
# NEXT_PUBLIC_API_URL="https://evaltravaux-api.onrender.com"

### Identifiant customer “public” utilisé pour créer les leads
# Cet identifiant doit exister côté base (table Customer).
# En dev, vous pouvez utiliser une valeur factice tant que l’API l’accepte.
NEXT_PUBLIC_PUBLIC_CUSTOMER_ID="public-customer-evaltravaux"

##############################################
# Notes de déploiement
#
# - Copiez ce fichier en .env.local pour le développement
# - Copiez/ajustez les valeurs dans les variables d’environnement
#   de votre hébergeur (Render, Vercel) pour la production.
##############################################

